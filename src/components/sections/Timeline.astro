---
import { getCollection } from 'astro:content';
import { formatDate } from '@/utils/format';
import { inlineMarkdownToHtml } from '@/utils/markdown';
import SectionHeading from '@/components/ui/SectionHeading.astro';

const items = (await getCollection('news')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
---
<section id="news" class="timeline container">
  <SectionHeading kicker="Timeline" title="News & milestones" />
  <!-- data-lenis-prevent lets this box scroll natively instead of being hijacked
       by the page's Lenis smooth-scroll -->
  <div class="news-window" data-lenis-prevent>
    <ul class="news-list">
      {items.map((item) => (
        <li class="news-item">
          <span class="news-item__date">{formatDate(item.data.date)}</span>
          <span class="news-item__text" set:html={inlineMarkdownToHtml(item.data.text)} />
        </li>
      ))}
    </ul>
  </div>
  <style>
    .timeline { padding-block: var(--space-xl); }
    .news-window {
      max-height: 26rem;
      overflow-y: auto;
      padding-right: 0.4rem;
      scrollbar-width: thin;
      scrollbar-color: var(--border) transparent;
    }
    .news-window::-webkit-scrollbar { width: 8px; }
    .news-window::-webkit-scrollbar-thumb { background: var(--border); border-radius: 8px; }
    .news-window::-webkit-scrollbar-track { background: transparent; }

    .news-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.75rem; }
    /* each news = its own bordered frame */
    .news-item {
      display: flex;
      align-items: stretch;
      background: var(--surface);
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent-from);
      border-radius: 12px;
      overflow: hidden;
      transition: border-color 0.25s var(--ease-out), box-shadow 0.25s var(--ease-out), transform 0.25s var(--ease-out);
    }
    .news-item:hover {
      border-color: color-mix(in srgb, var(--accent-from) 55%, var(--border));
      box-shadow: 0 10px 28px rgba(0, 0, 0, 0.35);
      transform: translateY(-2px);
    }
    .news-item__date {
      flex: 0 0 8rem;
      display: flex;
      align-items: center;
      padding: 0.85rem 1rem;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--text-muted);
      white-space: nowrap;
      border-right: 1px solid var(--border);
    }
    .news-item__text {
      display: flex;
      align-items: center;
      padding: 0.85rem 1.25rem;
      font-size: var(--step-0);
      line-height: 1.55;
      color: var(--text);
    }
    .news-item__text :global(a) { color: var(--accent-from); text-decoration: underline; }
    @media (max-width: 560px) {
      .news-item { flex-direction: column; align-items: flex-start; }
      .news-item__date { flex-basis: auto; border-right: none; padding-bottom: 0.2rem; }
      .news-item__text { padding-top: 0.2rem; }
    }
  </style>
</section>
