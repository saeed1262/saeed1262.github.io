---
import { getCollection } from 'astro:content';
import { formatDate } from '@/utils/format';
import { inlineMarkdownToHtml } from '@/utils/markdown';
import SectionHeading from '@/components/ui/SectionHeading.astro';

const items = (await getCollection('news')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
---
<section id="news" class="timeline container">
  <SectionHeading kicker="Timeline" title="News & milestones" />
  <!-- data-lenis-prevent lets this box scroll natively instead of being hijacked
       by the page's Lenis smooth-scroll -->
  <div class="news-window" data-lenis-prevent>
    <ol class="news-list">
      {items.map((item) => (
        <li class="news-card">
          <time class="news-card__date">{formatDate(item.data.date)}</time>
          <p class="news-card__text" set:html={inlineMarkdownToHtml(item.data.text)} />
        </li>
      ))}
    </ol>
  </div>
  <style>
    .timeline { padding-block: var(--space-xl); }
    .news-window {
      max-height: 24rem;
      overflow-y: auto;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: var(--space-sm);
      scrollbar-width: thin;
      scrollbar-color: var(--border) transparent;
    }
    .news-window::-webkit-scrollbar { width: 8px; }
    .news-window::-webkit-scrollbar-thumb { background: var(--border); border-radius: 8px; }
    .news-window::-webkit-scrollbar-track { background: transparent; }
    .news-list { list-style: none; margin: 0; padding: 0; display: grid; gap: var(--space-sm); }
    .news-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: var(--space-sm) var(--space-md);
      transition: border-color 0.3s var(--ease-out), transform 0.3s var(--ease-out);
    }
    .news-card:hover {
      border-color: color-mix(in srgb, var(--accent-from) 45%, var(--border));
      transform: translateX(4px);
    }
    .news-card__date { color: var(--accent-from); font-size: var(--step--1); }
    .news-card__text { color: var(--text); margin-top: 0.25rem; }
    .news-card__text :global(a) { color: var(--accent-from); text-decoration: underline; }
  </style>
</section>
