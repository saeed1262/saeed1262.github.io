---
import { Image } from 'astro:assets';
import Reveal from '@/components/ui/Reveal.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { site } from '@/data/site';
import headshot from '@/assets/saeed.jpg';
---
<section id="about" class="about container">
  <SectionHeading kicker="About" title="Hello, I'm Saeed." />
  <div class="about__grid">
    <Reveal class="about__bio">
      <p>
        I'm a senior machine learning engineer at Roper, working on agentic AI.
        I like working end to end, from research and modeling through to shipping
        things that hold up in production.
      </p>
      <p>
        My background spans deep learning, computer vision, and generative models.
        PhD from York University; previously a research scientist at Wētā FX,
        Amazon Games, and Ubisoft La Forge.
      </p>
    </Reveal>
    <Reveal class="about__photo">
      <!-- elements below live in About's template, so they carry About's scope id and
           the hover/clip selectors actually match (the Reveal root does NOT) -->
      <div class="about__card">
        <div class="about__frame">
          <Image
            class="about__img"
            src={headshot}
            alt="Saeed Ghorbani"
            width={400}
            height={400}
            loading="lazy"
          />
        </div>
        <div class="profile">
          <p class="profile__role">{site.position}</p>
          <p class="profile__org">{site.company}</p>
          <p class="profile__loc">{site.location}</p>
          <a class="profile__contact" href={`mailto:${site.email}`}>Contact →</a>
        </div>
      </div>
    </Reveal>
  </div>
  <style>
    .about { padding-block: var(--space-xl); }
    .about__grid { display: grid; gap: var(--space-lg); grid-template-columns: 1.4fr 1fr; align-items: center; }
    .about__bio p + p { margin-top: var(--space-sm); color: var(--text-muted); }
    .about__card { display: grid; gap: var(--space-md); justify-items: center; }
    .about__frame { cursor: pointer; width: 100%; }
    /* profile card: role / company / location / contact */
    .profile {
      width: 100%;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: var(--space-md);
      box-shadow: var(--shadow-card);
      text-align: center;
    }
    .profile__role { font-family: var(--font-display); font-weight: 600; font-size: var(--step-1); }
    .profile__org { color: var(--text); margin-top: 0.25rem; }
    .profile__loc { color: var(--text-muted); font-size: var(--step--1); margin-top: 0.15rem; }
    .profile__contact { display: inline-block; margin-top: var(--space-sm); color: var(--accent-from); font-weight: 500; }
    .profile__contact:hover { text-decoration: underline; }
    /* circle by default — clip-path: circle() is a true circle on any box ratio —
       grows past the box on hover so the full photo shows */
    .about__img {
      width: 100%;
      height: auto;
      -webkit-clip-path: circle(46% at 50% 50%);
      clip-path: circle(46% at 50% 50%);
      transition: clip-path 0.6s var(--ease-out), -webkit-clip-path 0.6s var(--ease-out);
    }
    .about__frame:hover .about__img,
    .about__frame:focus-within .about__img {
      -webkit-clip-path: circle(75% at 50% 50%);
      clip-path: circle(75% at 50% 50%);
    }
    @media (max-width: 768px) { .about__grid { grid-template-columns: 1fr; } }
    @media (prefers-reduced-motion: reduce) {
      .about__img {
        -webkit-clip-path: circle(75% at 50% 50%);
        clip-path: circle(75% at 50% 50%);
        transition: none;
      }
    }
  </style>
</section>
