---
import { Image } from 'astro:assets';
import Reveal from '@/components/ui/Reveal.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import headshot from '@/assets/prof_pic.jpg';
---
<section id="about" class="about container">
  <SectionHeading kicker="About" title="Hello, I'm Saeed." />
  <div class="about__grid">
    <Reveal class="about__bio">
      <p>
        I'm a machine learning engineer. My research background spans deep learning,
        computer vision, and human motion modeling — including probabilistic models,
        3D pose estimation, and gesture synthesis.
      </p>
      <p>Previously at Wētā FX, Amazon Games, and Ubisoft La Forge. PhD from York University.</p>
    </Reveal>
    <Reveal class="about__photo">
      <Image
        src={headshot}
        alt="Saeed Ghorbani"
        width={420}
        height={560}
        densities={[1, 2]}
        loading="lazy"
      />
    </Reveal>
  </div>
  <style>
    .about { padding-block: var(--space-xl); }
    .about__grid { display: grid; gap: var(--space-lg); grid-template-columns: 1.4fr 1fr; align-items: center; }
    .about__bio p + p { margin-top: var(--space-sm); color: var(--text-muted); }
    /* circle by default, expands to the full rectangle on hover (clip-path tweens
       smoothly because both states are inset() shapes) */
    /* circle by default (clip-path: circle() is always a true circle regardless of
       box ratio), grows to a circle larger than the box on hover = full photo shown */
    .about__photo img {
      width: 100%;
      height: auto;
      -webkit-clip-path: circle(42% at 50% 38%);
      clip-path: circle(42% at 50% 38%);
      transition: clip-path 0.6s var(--ease-out), -webkit-clip-path 0.6s var(--ease-out);
      cursor: pointer;
    }
    .about__photo:hover img,
    .about__photo:focus-within img {
      -webkit-clip-path: circle(75% at 50% 50%);
      clip-path: circle(75% at 50% 50%);
    }
    @media (max-width: 768px) { .about__grid { grid-template-columns: 1fr; } }
    @media (prefers-reduced-motion: reduce) {
      .about__photo img {
        -webkit-clip-path: circle(75% at 50% 50%);
        clip-path: circle(75% at 50% 50%);
        transition: none;
      }
    }
  </style>
</section>
