---
// Reusable wavy underline that morphs + reveals on hover.
// Dependency-free port of the 21st.dev "animated-underline-text-one" idea
// (originally React + Framer Motion) to scoped Astro + CSS.
// The SVG path `d` is animated via CSS in Chromium/Safari; Firefox (no CSS `d`
// animation yet) simply reveals the static wave via opacity — graceful fallback.
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---
<span class:list={['au', className]}>
  <span class="au__text"><slot /></span>
  <svg class="au__line" viewBox="0 0 300 20" preserveAspectRatio="none" aria-hidden="true" focusable="false">
    <path d="M 0,10 Q 75,0 150,10 Q 225,20 300,10" />
  </svg>
</span>

<style>
  .au {
    position: relative;
    display: inline-block;
  }
  .au__line {
    position: absolute;
    left: 0;
    bottom: -0.32em;
    width: 100%;
    height: 0.5em;
    overflow: visible;
    pointer-events: none;
  }
  .au__line path {
    fill: none;
    stroke: var(--accent-from);
    stroke-width: 2;
    stroke-linecap: round;
    opacity: 0;
    d: path('M 0,10 Q 75,0 150,10 Q 225,20 300,10');
    transition:
      d 0.5s var(--ease-out),
      opacity 0.35s var(--ease-out);
  }
  .au:hover .au__line path,
  .au:focus-within .au__line path {
    opacity: 1;
    d: path('M 0,10 Q 75,20 150,10 Q 225,0 300,10');
  }
  @media (prefers-reduced-motion: reduce) {
    .au__line path {
      transition: opacity 0.2s ease;
    }
  }
</style>
