---
interface Props {
  class?: string;
  color?: string;
  opacity?: number;
  brush?: number;
}
const { class: className, color = '#0a0b0f', opacity = 0.6, brush = 30 } = Astro.props;
---

<div
  class:list={['ink', className]}
  data-ink-color={color}
  data-ink-opacity={opacity}
  data-ink-brush={brush}
>
  <slot />
  <canvas class="ink__canvas" aria-hidden="true"></canvas>
</div>

<style>
  .ink {
    position: relative;
    display: block;
    overflow: hidden;
  }
  .ink__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .ink__canvas {
      display: none;
    }
  }
</style>

<script>
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduced) {
    document.querySelectorAll<HTMLElement>('.ink').forEach((host) => {
      const canvas = host.querySelector<HTMLCanvasElement>('.ink__canvas');
      if (!canvas) return;
      const io = new IntersectionObserver(async (entries) => {
        if (!entries[0].isIntersecting) return;
        io.disconnect();
        const { InkReveal } = await import('@/scripts/ink/inkReveal');
        const opacity = Number(host.dataset.inkOpacity);
        const brush = Number(host.dataset.inkBrush);
        new InkReveal(canvas, host, {
          color: host.dataset.inkColor,
          opacity: Number.isNaN(opacity) ? undefined : opacity,
          brush: Number.isNaN(brush) ? undefined : brush,
        });
      });
      io.observe(host);
    });
  }
</script>
