---
import { site } from '@/data/site';
import AnimatedUnderline from '@/components/ui/AnimatedUnderline.astro';
---
<section class="hero" aria-label="Intro">
  <div class="lamp" aria-hidden="true">
    <span class="lamp__glow"></span>
    <span class="lamp__line"></span>
  </div>
  <div class="hero__content container">
    <p class="hero__eyebrow">{site.role}</p>
    <h1 class="hero__title"><AnimatedUnderline>{site.name}</AnimatedUnderline></h1>
    <p class="hero__tagline accent-text">Machine learning, in motion.</p>
    <a class="hero__cue" href="#about">Scroll ↓</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: grid;
    place-items: center;
    overflow: hidden;
    /* page-spanning blue glow that fades smoothly to black at the edges — no frame */
    background:
      radial-gradient(135% 120% at 50% 30%,
        color-mix(in srgb, var(--accent-from) 26%, transparent) 0%,
        color-mix(in srgb, var(--accent-from) 13%, transparent) 36%,
        color-mix(in srgb, var(--accent-to) 6%, transparent) 58%,
        transparent 82%),
      var(--bg-deep);
    isolation: isolate;
  }
  .lamp {
    position: absolute;
    top: 38%;
    left: 50%;
    transform: translateX(-50%);
    width: min(60rem, 92vw);
    z-index: 0;
    pointer-events: none;
  }
  /* soft bright core right under the light line (heavily blurred = no hard edge) */
  .lamp__glow {
    position: absolute;
    top: -3rem;
    left: 50%;
    transform: translateX(-50%);
    width: 36rem;
    max-width: 88vw;
    height: 12rem;
    border-radius: 999px;
    background: var(--accent-from);
    filter: blur(120px);
    opacity: 0;
    animation: lamp-glow 1.3s var(--ease-out) 0.2s forwards;
  }
  /* the bright focal light line */
  .lamp__line {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%) scaleX(0);
    height: 2px;
    width: min(46rem, 90vw);
    background: linear-gradient(90deg, transparent, var(--accent-from) 26%, var(--accent-to) 74%, transparent);
    box-shadow: 0 0 30px 5px color-mix(in srgb, var(--accent-from) 55%, transparent);
    animation: lamp-line 1.1s var(--ease-out) 0.3s forwards;
  }
  @keyframes lamp-glow { to { opacity: 0.5; } }
  @keyframes lamp-line { to { transform: translateX(-50%) scaleX(1); } }
  /* content sits just beneath the light line */
  .hero__content {
    position: relative;
    z-index: 1;
    text-align: center;
    margin-top: 6rem;
    transform: translateY(2rem);
    opacity: 0;
    animation: hero-rise 0.9s var(--ease-out) 0.5s forwards;
  }
  @keyframes hero-rise { to { opacity: 1; transform: none; } }
  .hero__eyebrow { color: var(--text-muted); letter-spacing: 0.2em; text-transform: uppercase; font-size: var(--step--1); }
  .hero__title { font-size: var(--step-5); font-weight: 700; }
  .hero__tagline { font-size: var(--step-2); margin-top: var(--space-xs); }
  .hero__cue { display: inline-block; margin-top: var(--space-md); color: var(--text-muted); }
  @media (prefers-reduced-motion: reduce) {
    .lamp__glow { opacity: 0.5; animation: none; }
    .lamp__line { transform: translateX(-50%) scaleX(1); animation: none; }
    .hero__content { opacity: 1; transform: none; animation: none; }
  }
</style>
