---
import { site } from '@/data/site';
import AnimatedUnderline from '@/components/ui/AnimatedUnderline.astro';

// Build flowing SVG paths (Aceternity "Background Paths" idea), generated at build
// time and animated purely by CSS (a continuous stroke-dashoffset flow — no JS).
function buildPaths(position: number) {
  return Array.from({ length: 36 }, (_, i) => ({
    d: `M-${380 - i * 5 * position} -${189 + i * 6}C-${380 - i * 5 * position} -${189 + i * 6} -${312 - i * 5 * position} ${216 - i * 6} ${152 - i * 5 * position} ${343 - i * 6}C${616 - i * 5 * position} ${470 - i * 6} ${684 - i * 5 * position} ${875 - i * 6} ${684 - i * 5 * position} ${875 - i * 6}`,
    width: 0.5 + i * 0.03,
    opacity: 0.12 + i * 0.02,
    dur: 16 + (i % 12),
    delay: -(i * 0.6),
  }));
}
const groupA = buildPaths(1);
const groupB = buildPaths(-1);
// split into words (so the title can wrap) -> letters (each animated)
let li = 0;
const words = site.name.split(' ').map((word) =>
  [...word].map((ch) => ({ ch, delay: (li++ * 0.045).toFixed(3) })),
);
---
<section class="hero" aria-label="Intro">
  <div class="paths" aria-hidden="true">
    <svg class="paths__svg paths__svg--a" viewBox="0 0 696 316" fill="none" preserveAspectRatio="xMidYMid slice">
      {groupA.map((p) => (
        <path d={p.d} stroke="currentColor" stroke-width={p.width} stroke-opacity={p.opacity}
          pathLength="1" style={`--dur:${p.dur}s;--delay:${p.delay}s`} />
      ))}
    </svg>
    <svg class="paths__svg paths__svg--b" viewBox="0 0 696 316" fill="none" preserveAspectRatio="xMidYMid slice">
      {groupB.map((p) => (
        <path d={p.d} stroke="currentColor" stroke-width={p.width} stroke-opacity={p.opacity}
          pathLength="1" style={`--dur:${p.dur + 3}s;--delay:${p.delay - 1}s`} />
      ))}
    </svg>
  </div>
  <div class="hero__content container">
    <p class="hero__eyebrow">{site.role}</p>
    <h1 class="hero__title" aria-label={site.name}>
      <AnimatedUnderline>
        {words.map((chars, wi) => (
          <Fragment>
            <span class="hero__word">
              {chars.map(({ ch, delay }) => (
                <span class="hero__letter" aria-hidden="true" style={`animation-delay:${delay}s`}>{ch}</span>
              ))}
            </span>
            {wi < words.length - 1 ? ' ' : ''}
          </Fragment>
        ))}
      </AnimatedUnderline>
    </h1>
    <a class="hero__cue" href="#about">Scroll ↓</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: grid;
    place-items: center;
    overflow: hidden;
    background: var(--bg-deep);
    isolation: isolate;
  }
  /* --- flowing background paths (continuous, no flashing) --- */
  .paths { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .paths__svg { position: absolute; inset: 0; width: 100%; height: 100%; }
  .paths__svg--a { color: var(--accent-from); }
  .paths__svg--b { color: var(--accent-to); }
  .paths__svg path {
    fill: none;
    stroke-linecap: round;
    /* a dash + equal gap (pathLength=1) marching continuously along the curve */
    stroke-dasharray: 0.5 0.5;
    animation: path-flow var(--dur, 20s) linear var(--delay, 0s) infinite;
  }
  @keyframes path-flow {
    from { stroke-dashoffset: 0; }
    to { stroke-dashoffset: -1; }
  }
  /* soft radial vignette so the center text stays readable over the lines */
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background: radial-gradient(60% 50% at 50% 50%, color-mix(in srgb, var(--bg-deep) 78%, transparent), transparent 75%);
    pointer-events: none;
  }

  /* --- content --- */
  .hero__content { position: relative; z-index: 1; text-align: center; }
  .hero__eyebrow {
    color: var(--text-muted);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-size: var(--step--1);
    opacity: 0;
    animation: fade-in 0.8s var(--ease-out) 0.1s forwards;
  }
  .hero__title { font-size: var(--step-5); font-weight: 700; }
  .hero__word { display: inline-block; }
  .hero__letter {
    display: inline-block;
    opacity: 0;
    transform: translateY(0.4em);
    animation: letter-in 0.6s cubic-bezier(0.2, 0.8, 0.2, 1.2) forwards;
  }
  .hero__cue {
    display: inline-block;
    margin-top: var(--space-md);
    color: var(--text-muted);
    opacity: 0;
    animation: fade-in 0.8s var(--ease-out) 0.9s forwards;
  }
  @keyframes letter-in { to { opacity: 1; transform: none; } }
  @keyframes fade-in { to { opacity: 1; } }

  @media (prefers-reduced-motion: reduce) {
    .paths__svg path { animation: none; stroke-dasharray: none; opacity: 1; }
    .hero__eyebrow, .hero__cue { opacity: 1; animation: none; }
    .hero__letter { opacity: 1; transform: none; animation: none; }
  }
</style>
