---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const projectImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/projects/*', { eager: true });
function imageFor(file?: string) {
  if (!file) return undefined;
  return projectImages[`/src/assets/projects/${file}`]?.default;
}
const hero = imageFor(project.data.image);
---
<BaseLayout title={project.data.title} description={project.data.description}>
  <article class="project container">
    <a href="/#projects" class="project__back">← Projects</a>
    <h1>{project.data.title}</h1>
    <p class="project__desc">{project.data.description}</p>
    {project.data.tags.length > 0 && (
      <ul class="project__tags">{project.data.tags.map((t) => <li>{t}</li>)}</ul>
    )}
    {hero && <Image src={hero} alt={project.data.title} width={960} loading="eager" class="project__hero" />}
    {project.data.url && (
      <p class="project__cta"><Button href={project.data.url} variant="solid">Visit resource →</Button></p>
    )}
    <div class="project__body"><Content /></div>
  </article>
  <style>
    .project { padding-block: var(--space-xl); max-width: 48rem; }
    .project__back { color: var(--accent-from); font-size: var(--step--1); }
    .project h1 { font-size: var(--step-4); margin-top: var(--space-sm); }
    .project__desc { color: var(--text-muted); margin-top: var(--space-sm); }
    .project__tags { display: flex; flex-wrap: wrap; gap: 0.4rem; list-style: none; padding: 0; margin: var(--space-sm) 0; }
    .project__tags li { font-size: var(--step--1); color: var(--accent-from); border: 1px solid var(--border); border-radius: 999px; padding: 0.15rem 0.6rem; }
    .project__hero { border-radius: 12px; margin-block: var(--space-md); width: 100%; height: auto; }
    .project__cta { margin-block: var(--space-md); }
    .project__body { margin-top: var(--space-lg); }
    .project__body :global(p) { margin-bottom: var(--space-sm); }
    .project__body :global(h2) { margin-block: var(--space-md) var(--space-sm); font-size: var(--step-2); }
    .project__body :global(h3) { margin-block: var(--space-md) var(--space-sm); font-size: var(--step-1); }
    .project__body :global(ul) { margin-bottom: var(--space-sm); padding-left: 1.4rem; }
    .project__body :global(li) { margin-bottom: 0.35rem; }
    .project__body :global(a) { color: var(--accent-from); text-decoration: underline; }
    .project__body :global(img) { border-radius: 12px; margin-block: var(--space-md); max-width: 100%; height: auto; }
    .project__body :global(table) { width: 100%; border-collapse: collapse; margin-block: var(--space-md); }
    .project__body :global(th),
    .project__body :global(td) { border: 1px solid var(--border); padding: 0.5rem 0.75rem; text-align: left; }
    .project__body :global(pre) { overflow-x: auto; border-radius: 12px; padding: var(--space-sm); margin-block: var(--space-md); }
    .project__body :global(.video) { position: relative; aspect-ratio: 16 / 9; margin: var(--space-md) 0; }
    .project__body :global(.video iframe) { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; border-radius: 12px; }
    .project__body :global(.caption) { color: var(--text-muted); font-size: var(--step--1); text-align: center; margin-top: 0.5rem; }
  </style>
</BaseLayout>
